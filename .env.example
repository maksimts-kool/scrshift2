# Vercel frontend (public, embedded by Vite at build time)
VITE_RT_API_BASE=https://your-realtime-service.example

# Persistent real-time container/VPS (server secrets; never prefix these VITE_)
RT_MODE=hosted
RT_HOST=0.0.0.0
RT_ALLOW_ORIGIN=https://your-vercel-site.vercel.app
RT_ROBLOSECURITY=your-dedicated-service-account-cookie